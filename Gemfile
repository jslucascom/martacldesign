source "https://rubygems.org"

# The github-pages gem pins Jekyll (and its plugins) to the exact versions
# GitHub Pages runs when it builds your site — so what you see locally
# matches what goes live.
gem "github-pages", group: :jekyll_plugins

# Ruby 3.0+ no longer ships WEBrick in its standard library, and
# `jekyll serve` needs it for the local preview server.
gem "webrick", "~> 1.8"
